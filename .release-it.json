{
  "git": {
    "commitMessage": "chore(release): v${version}",
    "tagName": "v${version}",
    "push": true
  },
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "web": false
  },
  "npm": {
    "publish": true
  },
  "hooks": {
    "before:init": ["pnpm run lint", "pnpm run build"]
  }
}
