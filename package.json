    "nodes": [
      "dist/nodes/SocialPreview/SocialPreview.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.23.1",
    "@types/node": "^18.19.130",
    "fast-glob": "^3.3.3",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "satori": "^0.12.1",
    "satori-html": "^0.3.2"
